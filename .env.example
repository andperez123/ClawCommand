# ─── ClawCommand API ─────────────────────────────────────────────
# Port the API listens on
PORT=4000

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Set to "production" for production deployments
NODE_ENV=production

# ─── Authentication ──────────────────────────────────────────────
# Comma-separated list of valid API tokens
CLAWCOMMAND_TOKENS=your-secret-token-here

# Set to "1" to allow anonymous access (NOT recommended for production)
# CLAWCOMMAND_ALLOW_ANON=0

# ─── Database ────────────────────────────────────────────────────
# Path to SQLite database file
CLAWCOMMAND_DB_PATH=./data/clawcommand.db

# Set to "memory" to use in-memory store (data lost on restart)
# CLAWCOMMAND_STORE=memory

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated allowed origins (leave empty to allow all in dev)
CLAWCOMMAND_CORS_ORIGINS=https://your-dashboard.example.com

# ─── Rate Limiting ───────────────────────────────────────────────
# Max requests per IP per minute
CLAWCOMMAND_RATE_LIMIT=120

# ─── Dashboard ───────────────────────────────────────────────────
# API URL for the Next.js dashboard (set in packages/dashboard/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Scanner ─────────────────────────────────────────────────────
# API URL for the scanner CLI upload
CLAWCOMMAND_API_URL=http://localhost:4000
