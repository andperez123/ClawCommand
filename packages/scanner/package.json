{
  "name": "@clawcommand/scanner",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "openclaw-scan": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/openclaw-scan-bundle.mjs --banner:js='#!/usr/bin/env node'",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@clawcommand/shared": "*",
    "@clawcommand/parser": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
