#!/usr/bin/env bash
set -euo pipefail

# ClawCommand — one-command OpenClaw scanner
# Usage: ./scan [options]
# Run ./scan --help for all options

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

log()  { echo -e "${CYAN}▸${RESET} $*"; }
ok()   { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }
fail() { echo -e "${RED}✗${RESET} $*" >&2; exit 1; }

# ── Preflight ────────────────────────────────────────────────────

if ! command -v node &>/dev/null; then
  fail "Node.js is required (v18+). Install from https://nodejs.org"
fi

NODE_VERSION=$(node -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_VERSION" -lt 18 ]; then
  fail "Node.js v18+ required (found v$(node -v))"
fi

# ── Install dependencies if needed ──────────────────────────────

if [ ! -d node_modules ]; then
  log "Installing dependencies (first run)..."
  npm install --no-audit --no-fund --loglevel=error
  ok "Dependencies installed"
fi

# ── Build if needed ─────────────────────────────────────────────

if [ ! -f packages/scanner/dist/cli.js ]; then
  log "Building scanner (first run)..."
  npm run build --loglevel=error 2>&1 | tail -1
  ok "Build complete"
fi

# ── Run the scanner ─────────────────────────────────────────────

exec node packages/scanner/dist/cli.js "$@"
